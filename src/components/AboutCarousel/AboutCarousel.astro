---
import "./AboutCarousel.css"

const carouselImages = [
    { src: "images/machines/ipl-machine.jpg", alt: "Equipo IPL" },
    { src: "images/machines/ipl2-machine.jpg", alt: "Equipo IPL 2" },
    { src: "images/machines/laser-machine.jpg", alt: "Depilacion Laser" },
    { src: "images/machines/radiofrecuencia-machine.png", alt: "Radiofrecuencia" },
    { src: "images/machines/crioterapia-machine.png", alt: "Crioterapia" },
    { src: "images/machines/ultracavitacion-machine.jpg", alt: "Ultracavitación" },
    { src: "images/machines/picosecond-lamp-machine.jpg", alt: "Lámpara Picosecond" },
]
---

<div class="about-carousel">
    <div class="carousel-track">
        {carouselImages.map((image, index) => (
            <div class="carousel-slide">
                <img src={image.src} alt={image.alt} />
            </div>
        ))}
    </div>
    <div class="carousel-dots">
        {carouselImages.map((_, index) => (
            <button class:list={["carousel-dot", { active: index === 0 }]} data-index={index} aria-label={`Imagen ${index + 1}`}></button>
        ))}
    </div>
</div>

<script>
    const track = document.querySelector(".carousel-track") as HTMLElement
    const dots = document.querySelectorAll(".carousel-dot")
    const total = dots.length
    let current = 0
    let interval: ReturnType<typeof setInterval>

    function goTo(index: number) {
        current = index
        track.style.transform = `translateX(-${current * 100}%)`
        dots.forEach((dot, i) => dot.classList.toggle("active", i === current))
    }

    function next() {
        goTo((current + 1) % total)
    }

    dots.forEach((dot, i) => {
        dot.addEventListener("click", () => {
            clearInterval(interval)
            goTo(i)
            interval = setInterval(next, 3000)
        })
    })

    interval = setInterval(next, 3000)
</script>